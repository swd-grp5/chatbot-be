# App mode
SPRING_DOCKER_COMPOSE_ENABLED=false
SPRING_PORT=8080

# MySQL
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_DATABASE=swdchatbox
MYSQL_USER=swd_user
MYSQL_PASSWORD=swd_password
MYSQL_ROOT_PASSWORD=root_password
MYSQL_USE_SSL=false

# Public URLs
APP_PUBLIC_URL=https://api.edubuddy.site
VERIFY_BASE_URL=${APP_PUBLIC_URL}
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8081,https://edubuddy.site,http://168.144.98.120:5173

MYSQL_PORT=3307
SPRING_PORT=8080

GOOGLE_CLIENT_ID=

# VNPAY (Sandbox / TEST) - lay tu email cau hinh cua VNPAY
VNPAY_TMN_CODE=
VNPAY_HASH_SECRET=
VNPAY_RETURN_URL=http://localhost:8080/api/payments/vnpay/return
# Tuy chon: ghi de neu can
# VNPAY_PAY_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
# JWT
JWT_SECRET=change_this_to_a_long_random_secret
JWT_EXPIRATION_MS=86400000
JWT_SHORT_EXPIRATION_MS=3600000

# Google Sign-In
GOOGLE_CLIENT_ID=

# Mail (Resend)
RESEND_API_KEY=your_resend_api_key_here
SPRING_MAIL_FROM=no-reply@edubuddy.site
SPRING_MAIL_FROM_NAME=SWDChatBox
SPRING_MAIL_REPLY_TO=

# Upload & storage
MAX_FILE_SIZE=200MB
MAX_REQUEST_SIZE=250MB
STORAGE_DOCUMENTS_BASE_PATH=uploads/documents
STORAGE_DOCUMENTS_CHECKSUM_ALGORITHM=SHA-256
