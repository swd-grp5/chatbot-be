# Deploy BE (docker compose) — MySQL chạy riêng, không trong stack này
MYSQL_HOST=your-mysql-host
MYSQL_PORT=3306
MYSQL_DATABASE=swd_chatbox
MYSQL_USE_SSL=false
MYSQL_USER=swd_user
MYSQL_PASSWORD=

MYSQL_PORT=3307
SPRING_PORT=8080

# JWT
JWT_SECRET=change-me-use-a-long-random-string-at-least-32-characters
JWT_EXPIRATION_MS=86400000
JWT_SHORT_EXPIRATION_MS=3600000

# Mail
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-gmail-app-password
MAIL_FROM=your-email@gmail.com
MAIL_FROM_NAME=SWDChatBox
MAIL_REPLY_TO=
APP_PUBLIC_URL=http://localhost:8080
VERIFY_BASE_URL=http://localhost:8080
CORS_ALLOWED_ORIGINS=http://localhost:5173,https://your-fe-domain.com

# Upload & storage
MULTIPART_ENABLED=true
MAX_FILE_SIZE=200MB
MAX_REQUEST_SIZE=250MB
STORAGE_DOCUMENTS_BASE_PATH=uploads/documents
STORAGE_DOCUMENTS_CHECKSUM_ALGORITHM=SHA-256

GOOGLE_CLIENT_ID=

# VNPAY (Sandbox / TEST) - lay tu email cau hinh cua VNPAY
VNPAY_TMN_CODE=
VNPAY_HASH_SECRET=
VNPAY_RETURN_URL=http://localhost:8080/api/payments/vnpay/return
# Tuy chon: ghi de neu can
# VNPAY_PAY_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html