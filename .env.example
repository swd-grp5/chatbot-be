# Local dev: copy to .env and fill in values
# Portainer / docker-compose: set these in Stack → Environment variables
SPRING_DOCKER_COMPOSE_ENABLED=false

# MySQL (external host — not in docker-compose stack)
MYSQL_HOST=your-mysql-host
MYSQL_PORT=3306
MYSQL_DATABASE=swdchatbox
MYSQL_USE_SSL=false
MYSQL_USER=swd_user
MYSQL_PASSWORD=

# Optional: override JDBC URL / credentials directly (production)
# SPRING_DATASOURCE_URL=jdbc:mysql://host:3306/swdchatbox?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=Asia/Ho_Chi_Minh&characterEncoding=UTF-8
# SPRING_DATASOURCE_USERNAME=
# SPRING_DATASOURCE_PASSWORD=

SPRING_PORT=8080
SPRING_JPA_SHOW_SQL=false

# AI Configuration
AI_PROVIDER=gemini
GEMINI_API_KEY=AIzaSyDHz4loOxD7vic1ABrgFXGaOf1W5G1Uhy0
OPENAI_API_KEY=your_openai_api_key_here

# Qdrant Vector Database
QDRANT_HOST=localhost
QDRANT_PORT=6333

# JWT
JWT_SECRET=change-me-use-a-long-random-string-at-least-32-characters
JWT_EXPIRATION_MS=86400000
JWT_SHORT_EXPIRATION_MS=3600000

# Google Sign-In
GOOGLE_CLIENT_ID=

# Mail (Resend)
RESEND_API_KEY=
SPRING_MAIL_FROM=no-reply@your-domain.com
SPRING_MAIL_FROM_NAME=SWDChatBox
SPRING_MAIL_REPLY_TO=

# Public URLs
APP_PUBLIC_URL=http://localhost:8080
VERIFY_BASE_URL=http://localhost:8080
CORS_ALLOWED_ORIGINS=http://localhost:5173,https://your-fe-domain.com

# Multipart upload
MULTIPART_ENABLED=true
MAX_FILE_SIZE=200MB
MAX_REQUEST_SIZE=250MB

# Document storage (local fallback when AWS_S3_BUCKET is empty)
STORAGE_DOCUMENTS_BASE_PATH=uploads/documents
STORAGE_DOCUMENTS_CHECKSUM_ALGORITHM=SHA-256

# AWS S3 (leave AWS_S3_BUCKET empty to use local storage)
AWS_S3_BUCKET=
AWS_S3_REGION=ap-southeast-2
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_KEY_PREFIX=documents

# VNPAY (Sandbox / TEST) — get from VNPAY merchant email
VNPAY_TMN_CODE=
VNPAY_HASH_SECRET=
VNPAY_RETURN_URL=http://localhost:8080/payments/vnpay/return
# VNPAY_PAY_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
