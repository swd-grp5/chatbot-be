# Local dev: copy to .env and fill in values
SPRING_DOCKER_COMPOSE_ENABLED=false

# MySQL (external host — not in docker-compose stack)
MYSQL_HOST=your-mysql-host
MYSQL_PORT=3306
MYSQL_DATABASE=swdchatbox
MYSQL_USE_SSL=false
MYSQL_USER=swd_user
MYSQL_PASSWORD=

SPRING_PORT=8080

# AI Configuration
AI_PROVIDER=gemini
GEMINI_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# Qdrant Vector Database
QDRANT_HOST=localhost
QDRANT_PORT=6333

# JWT
JWT_SECRET=change-me-use-a-long-random-string-at-least-32-characters
JWT_EXPIRATION_MS=86400000
JWT_SHORT_EXPIRATION_MS=3600000

# Mail (Resend)
RESEND_API_KEY=
SPRING_MAIL_FROM=no-reply@your-domain.com
SPRING_MAIL_FROM_NAME=SWDChatBox
SPRING_MAIL_REPLY_TO=

# Public URLs
APP_PUBLIC_URL=http://localhost:8080
VERIFY_BASE_URL=http://localhost:8080
CORS_ALLOWED_ORIGINS=http://localhost:5173,https://your-fe-domain.com

# Upload & storage
MULTIPART_ENABLED=true
MAX_FILE_SIZE=200MB
MAX_REQUEST_SIZE=250MB
STORAGE_DOCUMENTS_BASE_PATH=uploads/documents
STORAGE_DOCUMENTS_CHECKSUM_ALGORITHM=SHA-256

GOOGLE_CLIENT_ID=

# VNPAY (Sandbox / TEST) — get from VNPAY merchant email
VNPAY_TMN_CODE=
VNPAY_HASH_SECRET=
VNPAY_RETURN_URL=http://localhost:8080/payments/vnpay/return
# Optional overrides:
# VNPAY_PAY_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
