MYSQL_DATABASE=swd_chatbox
MYSQL_USER=swd_user
MYSQL_PASSWORD=swd_password
MYSQL_ROOT_PASSWORD=root_password

MYSQL_PORT=3306
SPRING_PORT=8080

# JWT
JWT_SECRET=change-me-use-a-long-random-string-at-least-32-characters
JWT_EXPIRATION_MS=86400000
JWT_SHORT_EXPIRATION_MS=3600000

# Mail
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-gmail-app-password
MAIL_FROM=your-email@gmail.com
MAIL_FROM_NAME=SWDChatBox
MAIL_REPLY_TO=
APP_PUBLIC_URL=http://localhost:8080
VERIFY_BASE_URL=http://localhost:8080
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8081,https://edubuddy.site,http://168.144.98.120

# Upload & storage
MULTIPART_ENABLED=true
MAX_FILE_SIZE=200MB
MAX_REQUEST_SIZE=250MB
STORAGE_DOCUMENTS_BASE_PATH=uploads/documents
STORAGE_DOCUMENTS_CHECKSUM_ALGORITHM=SHA-256

GOOGLE_CLIENT_ID=